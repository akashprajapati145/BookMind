GOOGLE_API_KEY=

# Optional — additional Gemini keys to rotate across. Free-tier keys are capped at
# 20 requests/min and 250k input tokens/min EACH, so using keys from separate
# Google accounts/projects multiplies effective throughput. All are optional;
# the app works with just GOOGLE_API_KEY alone.
GOOGLE_API_KEY_FALLBACK=
GOOGLE_API_KEY_FALLBACK_2=
GOOGLE_API_KEY_FALLBACK_3=
